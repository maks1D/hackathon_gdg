{
  "name": "@hackathon/source",
  "version": "0.0.1",
  "private": true,
  "description": "GDG Build with AI — Hackathon Monorepo (Angular + NestJS + Nx)",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npx nx serve api\" \"npx nx serve client\"",
    "start:api": "npx nx serve api",
    "start:client": "npx nx serve client",
    "build": "npx nx run-many --target=build --projects=client,api",
    "build:api": "npx nx build api",
    "build:client": "npx nx build client",
    "lint": "npx nx run-many --target=lint --projects=client,api,shared,http",
    "test": "npx nx run-many --target=test --projects=client,api",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "graph": "npx nx graph"
  },
  "dependencies": {
    "@angular/animations": "^20.3.17",
    "@angular/common": "^20.3.17",
    "@angular/compiler": "^20.3.17",
    "@angular/core": "^20.3.17",
    "@angular/forms": "^20.3.17",
    "@angular/platform-browser": "^20.3.17",
    "@angular/platform-browser-dynamic": "^20.3.17",
    "@angular/router": "^20.3.17",
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/client": "^5.22.0",
    "cache-manager": "^6.1.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zod": "^3.24.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2003.17",
    "@angular-devkit/core": "^20.3.17",
    "@angular-devkit/schematics": "^20.3.17",
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/build": "^20.3.17",
    "@angular/cli": "^20.3.17",
    "@angular/compiler-cli": "^20.3.17",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@nx/angular": "^23.0.1",
    "@nx/eslint": "^23.0.1",
    "@nx/eslint-plugin": "^23.0.1",
    "@nx/js": "^23.0.1",
    "@nx/nest": "^23.0.1",
    "@nx/node": "^23.0.1",
    "@nx/web": "^23.0.1",
    "@nx/webpack": "^23.0.1",
    "@nx/workspace": "^23.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.21.0",
